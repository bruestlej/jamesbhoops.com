# Canonical site URL (no trailing slash)
VITE_PUBLIC_SITE_ORIGIN=https://jamesbhoops.com

# Kit inline form embed — Form → Embed → JavaScript
# data-uid from the <script> tag:
VITE_KIT_FORM_UID=
# full script src URL, e.g. https://yourname.kit.com/abc123.js
VITE_KIT_FORM_SCRIPT_URL=

# On Vercel: add the same VITE_* variables in Project → Settings → Environment Variables,
# then redeploy. Local .env is not used by Vercel builds unless you set vars in the dashboard.
